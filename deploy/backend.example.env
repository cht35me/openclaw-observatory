# Observatory backend configuration — EXAMPLE.
#
# Copy to ~/.config/observatory/backend.env, replace every placeholder, and
# chmod 600 the file. NEVER commit real values (docs/security.md §5).
# systemd EnvironmentFile format: plain VAR=VALUE lines.

# --- ClickHouse (SD-005; native binary on RPSG01, loopback only) ---
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=observatory
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# --- Collector API keys (SD-017: each key bound to exactly one Fleet ID) ---
# Generate real keys with: openssl rand -hex 32
API_KEYS=RPSG01:change-me-host-collector-key,A001:change-me-agent-collector-key

# --- Service behaviour ---
LOG_LEVEL=INFO
APP_VERSION=0.1.0
# Git commit shown in the /monitor deployment header. Leave unset when the
# backend runs from a git checkout (auto-detected from .git, stdlib-only);
# set it explicitly for non-checkout deployments, e.g. container builds.
#GIT_COMMIT=

# --- Monitor display timezone (M003.6 §3) ---
# IANA timezone for wall-clock values on /monitor ("Last reboot"), shown
# with an explicit offset suffix, e.g. "Today 20:52 (+08)". Leave unset to
# use the host's local timezone; internal timestamps and the "generated …
# UTC" footer stay UTC. Invalid names fall back to the host timezone.
#DISPLAY_TZ=Asia/Singapore

# --- Heartbeats / offline detection (M003 §5/§6) ---
HEARTBEAT_INTERVAL=30
OFFLINE_TIMEOUT=90
OFFLINE_CHECK_INTERVAL=15
