# OpenClaw Observatory — example environment configuration.
#
# Copy to `.env` and replace every placeholder with a real value.
# `.env` is gitignored; NEVER commit real secrets (docs/security.md §5).

# --- ClickHouse (used by both the clickhouse and backend services) ---
CLICKHOUSE_DATABASE=observatory
CLICKHOUSE_USERNAME=observatory
CLICKHOUSE_PASSWORD=change-me-strong-database-password

# --- Collector authentication ---
# Comma-separated (or JSON array) of accepted collector API keys.
# Issue one key per collector so each can be revoked individually.
API_KEYS=change-me-collector-key-1,change-me-collector-key-2

# --- Service behaviour ---
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# --- Host port binding for the backend (compose only) ---
# Keep loopback (or a tailnet IP); never bind a public interface directly.
BACKEND_BIND=127.0.0.1
BACKEND_PORT=8000
