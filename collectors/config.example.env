# Observatory collector configuration — EXAMPLE (Mission M003 §8).
#
# Copy per collector (e.g. ~/.config/observatory/host-collector.env), replace
# every placeholder, and chmod 600 the file. NEVER commit real values
# (docs/security.md §5).

# --- Destination ---
OBSERVATORY_URL=http://127.0.0.1:8000

# --- Identity + credential (SD-017: the key is bound to this FLEET_ID) ---
FLEET_ID=RPSG01
OBSERVATORY_API_KEY=change-me-collector-key
# ... or point at a tight-permission file instead of inlining the key:
# OBSERVATORY_API_KEY_FILE=/home/user/.config/observatory/collector.key

# --- Naming and cadence ---
COLLECTOR_NAME=host-pi
HEARTBEAT_INTERVAL=30
# TELEMETRY_INTERVAL defaults to HEARTBEAT_INTERVAL
# TELEMETRY_INTERVAL=30
MISSION_POLL_INTERVAL=60
# Host-inventory re-report cadence (host collector; M003.5 §3).
# Inventory is also sent on start and when durable identity changes.
# INVENTORY_INTERVAL=3600
# REQUEST_TIMEOUT=10
# MAX_RETRIES=3

# --- OpenClaw agent collector only ---
# AGENT_STATE_FILE=/home/openclaw/observatory/agent-state.json
# AGENT_PROCESS_PATTERN=openclaw
# AGENT_MODEL_ID=anthropic/claude-fable-5
# Explicit executable paths for the CLI probes (M003.6 §1). The systemd
# user unit runs with a minimal PATH (/usr/bin:...) that misses per-user
# installs, so point these at the real binaries; unset = discover on PATH.
# OPENCLAW_BIN's sibling `node` is also used for the runtime Node version.
# CLAUDE_BIN=/home/user/.local/bin/claude
# OPENCLAW_BIN=/home/user/.openclaw/tools/node-v24.15.0/bin/openclaw
